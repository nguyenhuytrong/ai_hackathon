# Backend env: copy to backend/.env
APP_NAME=CareBridge Navigator API
APP_VERSION=0.1.0
API_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://carebridge:carebridge_dev@localhost:5432/carebridge
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-carebridge-v1
EMBEDDING_DIMENSIONS=64
EMBEDDING_API_KEY=

# Optional. Leave disabled for credential-free local demos.
REHAB_SNAPSHOT_LLM_ENABLED=false
GROQ_API_KEY=
REHAB_SNAPSHOT_MODEL=llama-3.3-70b-versatile
